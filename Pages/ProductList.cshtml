@page "/api/products/list"
@model CatalogService.Pages.ProductListModel
<!DOCTYPE html>
<html>
<head>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.0.2/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-EVSTQN3/azprG1Anm3QDgpJLIm9Nao0Yz1ztcQTwFspd3yD65VohhpuuC0mLASJC" crossorigin="anonymous">
    <meta name="viewport" content="width=device-width" />
    <title>Products</title>
    <style>
        table { border-collapse: collapse; }
        th, td { border: 1px solid blue; padding: 6px 12px; }
    </style>
</head>
<body>
    <div style="width: 1000px; margin: auto">
        <h1>Products</h1>
        <hr />
        @if (Model.Products != null)
        {
            <table>
                <thead>
                    <tr>
                        <th>Id</th>
                        <th>Name</th>
                        <th>Brand</th>
                        <th>Category</th>
                        <th>Price</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.Products)
                    {
                        <tr>
                            <td>@item.Id</td>
                            <td>@item.Name</td>
                            <td>@item.Brand</td>
                            <td>@item.Category</td>
                            <td>@item.Price kr.</td>
                        </tr>
                    }
                </tbody>
            </table>
        }
        <hr />
        <a href="/api/products/create" class="btn btn-primary">Create new product</a>
    </div>
</body>
</html>
